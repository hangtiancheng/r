{
  "name": "@lark-resume/pdf",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    }
  },
  "scripts": {
    "build": "pnpm build:rollup",
    "build:all": "pnpm build:tsc && pnpm build:rollup && pnpm build:tsup",
    "build:rollup": "rollup -c ./rollup.config.js",
    "build:tsc": "tsc -p ./tsconfig.json",
    "build:tsup": "tsup --config ./tsup.config.ts",
    "lint": "eslint --fix ./"
  },
  "dependencies": {
    "html2canvas": "^1.4.1",
    "pdfjs-dist": "^5.7.284"
  },
  "devDependencies": {
    "@rollup/plugin-typescript": "^12.3.0",
    "rollup": "^4.60.4",
    "tslib": "^2.8.1",
    "tsup": "^8.5.1",
    "typescript": "~6.0.3"
  }
}
