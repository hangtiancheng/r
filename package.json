{
  "name": "@swifty.js/resume",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint --fix ./",
    "git:commit": "git add -A && git commit -m \"feat: Introduce new features\"",
    "git:commit:ci": "git add -A && git commit -m \"ci: Deploy resume\"",
    "git:push": "pnpm git:commit && git push origin main",
    "git:push:ci": "pnpm git:commit:ci && git push origin main",
    "pwa": "pnpm dlx @vite-pwa/assets-generator --preset minimal public/favicon.svg",
    "preview": "vite preview",
    "format": "prettier -w ./ --experimental-cli"
  },
  "dependencies": {
    "@preact/signals": "^2.3.1",
    "@swifty.js/sentry": "^0.0.2",
    "daisyui": "^5.6.10",
    "i18next": "^26.3.4",
    "@swifty.js/preact": "^0.0.3",
    "tailwindcss": "^4.3.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.1",
    "@tailwindcss/vite": "^4.3.2",
    "@types/node": "^24.13.2",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0"
  }
}
