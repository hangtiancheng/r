{
  "name": "resume",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint --fix ./",
    "git:commit": "git add -A && git commit -m \"feat: Introduce new features\"",
    "git:commit:ci": "git add -A && git commit -m \"ci: Deploy resume\"",
    "git:push": "pnpm git:commit && git push origin main",
    "git:push:ci": "pnpm git:commit:ci && git push origin main",
    "pwa": "pnpm dlx @vite-pwa/assets-generator --preset minimal public/favicon.svg",
    "preview": "vite preview",
    "format": "prettier -w ./ --experimental-cli"
  },
  "dependencies": {
    "@lit/react": "^1.0.8",
    "@preact/signals": "^2.9.4",
    "@swifty.js/preact": "^0.0.3",
    "@swifty.js/sentry": "^0.0.2",
    "i18next": "^26.3.6",
    "lit": "^3.3.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tailwindcss": "^4.3.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@preact/preset-vite": "^2.10.5",
    "@tailwindcss/vite": "^4.3.3",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "preact": "^10.29.7",
    "prettier": "^3.9.5",
    "prettier-plugin-tailwindcss": "^0.8.1",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.64.0",
    "vite": "^8.1.5",
    "vite-plugin-pwa": "^1.3.0"
  }
}
